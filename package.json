{
  "name": "@svehrenkamp/create-agent-workflow",
  "version": "0.1.1",
  "description": "Scaffold an AI agent workflow framework into any project — subagents, commands, skills, and conventions for Claude Code and OpenCode",
  "type": "module",
  "bin": {
    "create-agent-workflow": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "workflow",
    "scaffold",
    "claude",
    "claude-code",
    "opencode",
    "subagent",
    "tdd",
    "code-review",
    "project-management"
  ],
  "author": "SVehrenkamp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SVehrenkamp/create-agent-workflow.git"
  },
  "homepage": "https://github.com/SVehrenkamp/create-agent-workflow#readme",
  "bugs": {
    "url": "https://github.com/SVehrenkamp/create-agent-workflow/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "templates"
  ],
  "dependencies": {
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.3.3"
  }
